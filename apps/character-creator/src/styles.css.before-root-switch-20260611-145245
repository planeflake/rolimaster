  display: grid;
  gap: 5px;
  border: 1px solid #e2d9cc;
  border-radius: 6px;
  background: #f7f0e4;
  padding: 10px;
}

.modal-facts b {
  color: #6a6258;
  font-size: 0.74rem;
  text-transform: uppercase;
}

.modal-note-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  gap: 10px;
  margin-top: 10px;
}

.modal-note-grid span {
  display: grid;
  gap: 5px;
  border: 1px solid #e2d9cc;
  border-radius: 6px;
  background: #f7f0e4;
  padding: 10px;
  line-height: 1.35;
}

.modal-note-grid b {
  color: #6a6258;
  font-size: 0.74rem;
  text-transform: uppercase;
}

.profession-modal-layout {
  display: grid;
  grid-template-columns: minmax(0, 0.95fr) minmax(340px, 1.05fr);
  gap: 16px;
  align-items: start;
}

.profession-modal-main {
  min-width: 0;
}

.modal-choice-groups {
  display: grid;
  gap: 12px;
}

.modal-choice-groups h3 {
  margin: 0 0 7px;
  color: #4f493f;
  font-size: 0.9rem;
}

.modal-choice-list {
  display: flex;
  flex-wrap: wrap;
  gap: 7px;
}

.modal-choice-list button,
.modal-category-list button {
  border: 1px solid #bdb3a3;
  border-radius: 6px;
  background: #fbf7ef;
  color: #302b25;
  padding: 7px 9px;
  font: inherit;
  font-size: 0.82rem;
  font-weight: 700;
  text-align: left;
}

.modal-choice-list button.active,
.modal-category-list button.active,
.modal-table-button.active {
  border-color: #427263;
  background: #e0eee8;
  color: #1e4a3b;
}

.modal-table-button {
  width: 100%;
  border: 1px solid #d5d0c6;
  border-radius: 6px;
  background: #fbf7ef;
  color: #302b25;
  padding: 6px 8px;
  font: inherit;
  font-weight: 700;
  text-align: left;
}

.modal-category-list {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
  gap: 7px;
}

.modal-category-list button {
  display: flex;
  justify-content: space-between;
  gap: 10px;
  align-items: baseline;
}

.modal-category-list b {
  color: inherit;
  white-space: nowrap;
}

.profession-modal-inspector {
  position: sticky;
  top: 0;
  display: grid;
  gap: 10px;
  max-height: calc(100vh - 150px);
  overflow: auto;
  border: 1px solid #d5d0c6;
  border-radius: 8px;
  background: #f7f0e4;
  padding: 14px;
}

.profession-modal-inspector > p:first-child {
  margin: 0;
  color: #6a6258;
  font-size: 0.74rem;
  font-weight: 800;
  text-transform: uppercase;
}

.profession-modal-inspector h2 {
  margin: 0;
}

.profession-modal-inspector small {
  color: #6a6258;
  line-height: 1.35;
}

.profession-modal-inspector ul {
  display: grid;
  gap: 6px;
  margin: 0;
  padding: 0;
  list-style: none;
}

.profession-modal-inspector li {
  display: grid;
  grid-template-columns: minmax(120px, 0.42fr) minmax(0, 1fr);
  gap: 12px;
  border-bottom: 1px solid #e2d9cc;
  padding-bottom: 6px;
  font-size: 0.86rem;
}

.profession-modal-inspector li span {
  color: #7a7060;
  line-height: 1.35;
}

.spell-table--modal {
  border: 1px solid #e2d9cc;
  background: #fffaf1;
}

.spell-table--modal .spell-row {
  grid-template-columns: 38px minmax(130px, 0.8fr) 68px 54px minmax(220px, 1.35fr);
  padding: 7px 9px;
  font-size: 0.78rem;
}

.muted {
  color: #7a7060;
}

.compact-table--modal {
  max-height: 360px;
  overflow: auto;
}

.preline {
  white-space: pre-line;
}

.chip-bar {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 6px;
  margin-bottom: 14px;
}

.filter-stack {
  display: grid;
  gap: 4px;
  margin-bottom: 14px;
}

.filter-stack .chip-bar {
  margin-bottom: 0;
}

.chip-label {
  color: #6a6258;
  font-size: 0.74rem;
  font-weight: 800;
  text-transform: uppercase;
  min-width: 82px;
}

.chip {
  border: 1px solid #bdb3a3;
  border-radius: 999px;
  background: #fbf7ef;
  color: #302b25;
  padding: 5px 14px;
  font-size: 0.82rem;
  font-weight: 600;
  min-height: auto;
  white-space: nowrap;
}

.chip.active {
  border-color: #427263;
  background: #e0eee8;
  color: #1e4a3b;
}

.chip-clear {
  border-color: #b98273;
  color: #7e2f22;
}

.chip-count {
  margin-left: auto;
  color: #6a6258;
  font-size: 0.88rem;
}

.rank-control {
  display: flex;
  align-items: center;
  gap: 6px;
}

.rank-control b {
  min-width: 28px;
  text-align: center;
}

.rank-btn {
  width: 28px;
  height: 28px;
  padding: 0;
  border: 1px solid #bdb3a3;
  border-radius: 6px;
  background: #fbf7ef;
  color: #302b25;
  font-size: 1rem;
  font-weight: 700;
  line-height: 1;
  min-height: auto;
}

.rank-btn--add {
  border-color: #427263;
  background: #e0eee8;
  color: #1e4a3b;
}

.rank-btn:disabled {
  opacity: 0.35;
  cursor: not-allowed;
}

.spell-layout {
  display: grid;
  grid-template-columns: minmax(280px, 0.36fr) minmax(0, 0.64fr);
  gap: 14px;
  align-items: start;
}

.spell-list-column {
  display: grid;
  gap: 10px;
}

.spell-info-bar {
  display: flex;
  align-items: stretch;
  gap: 0;
  border: 1px solid #d5d0c6;
  border-radius: 6px;
  background: #fffaf1;
  margin-bottom: 14px;
  overflow: hidden;
}

.spell-info-stat {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 2px;
  padding: 10px 24px;
  border-right: 1px solid #e2d9cc;
  flex: 1;
}

.spell-info-stat:last-child {
  border-right: none;
}

.spell-info-stat strong {
  font-size: 1.4rem;
  line-height: 1;
}

.spell-info-stat--input {
  align-items: center;
}

.spell-info-label {
  font-size: 0.68rem;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  color: #7a7060;
}

.spell-info-pool {
  display: flex;
  align-items: center;
  gap: 8px;
  width: 100%;
}

.spell-info-pool input {
  width: 72px;
  padding: 5px 8px;
  font-size: 0.9rem;
}

.spell-info-pool span {
  font-size: 0.82rem;
  font-weight: 600;
  color: #4f493f;
  white-space: nowrap;
}

.spell-info-pool span.over {
  color: #8b2a2a;
}


.spell-detail-column {
  display: grid;
  gap: 0;
  align-content: start;
}

.spell-list-tabs {
  display: flex;
  flex-wrap: wrap;
  gap: 4px;
  padding: 0 0 8px;
}

.spell-list-tab {
  border: 1px solid #bdb3a3;
  border-radius: 6px;
  background: #fbf7ef;
  color: #302b25;
  padding: 6px 12px;
  font-size: 0.82rem;
  font-weight: 600;
  min-height: auto;
  white-space: nowrap;
}

.spell-list-tab.active {
  border-color: #427263;
  background: #e0eee8;
  color: #1e4a3b;
}

.spell-tab-count {
  margin-left: 6px;
  font-size: 0.74rem;
  font-weight: 700;
  opacity: 0.65;
}

.spell-list-tab.active .spell-tab-count {
  opacity: 1;
}

.spell-rank-control {
  display: flex;
  align-items: center;
  gap: 8px;
  flex-shrink: 0;
}

.spell-rank-display {
  display: flex;
  align-items: baseline;
  gap: 3px;
  min-width: 44px;
  justify-content: center;
}

.spell-rank-display b {
  font-size: 1.3rem;
  font-weight: 800;
  line-height: 1;
}

.spell-row--known {
  background: #f0f8f4;
}

.spell-row--known b {
  color: #1e4a3b;
}

.spell-type-badge {
  display: inline-block;
  position: relative;
  border: 1px solid #bdb3a3;
  border-radius: 4px;
  background: #f5efe5;
  color: #4f493f;
  font-size: 0.72rem;
  font-weight: 800;
  padding: 1px 6px;
  cursor: help;
  white-space: nowrap;
}

.spell-type-badge::after {
  content: attr(data-tooltip);
  position: absolute;
  bottom: calc(100% + 7px);
  left: 50%;
  transform: translateX(-50%);
  width: 280px;
  background: #2d2820;
  color: #fffdf8;
  font-size: 0.78rem;
  font-weight: 400;
  line-height: 1.5;
  padding: 9px 12px;
  border-radius: 6px;
  white-space: normal;
  z-index: 200;
  pointer-events: none;
  opacity: 0;
  transition: opacity 0.1s;
}

.spell-type-badge:hover::after {
  opacity: 1;
}

.spell-list-card,
.spell-detail,
.empty-state {
  border: 1px solid #d5d0c6;
  border-radius: 6px;
  background: #fffaf1;
}

.spell-list-card {
  display: grid;
  gap: 10px;
  padding: 12px;
}

.spell-list-card.selected {
  border-color: #427263;
  background: #e0eee8;
}

.spell-list-card label {
  display: flex;
  align-items: start;
  gap: 9px;
}

.spell-list-card input {
  width: auto;
  margin-top: 3px;
}

.spell-list-card label span {
  display: grid;
  gap: 2px;
}

.spell-list-card p {
  margin: 0;
  color: #49443d;
  font-size: 0.88rem;
  line-height: 1.35;
}

.spell-detail {
  overflow: hidden;
}

.spell-detail > header {
  display: flex;
  align-items: start;
  justify-content: space-between;
  gap: 12px;
  border-bottom: 1px solid #d5d0c6;
  background: #f2eadc;
  padding: 12px;
}

.spell-detail header p {
  margin: 0;
  color: #6a6258;
  font-size: 0.82rem;
}

.spell-detail header small {
  display: block;
  max-width: 72ch;
  margin-top: 5px;
  line-height: 1.35;
}

.spell-table {
  display: grid;
}

.spell-row {
  display: grid;
  grid-template-columns: 46px minmax(150px, 0.8fr) 84px 58px minmax(240px, 1.4fr);
  gap: 10px;
  border-bottom: 1px solid #e2d9cc;
  padding: 8px 12px;
  align-items: start;
  font-size: 0.86rem;
}

.spell-row:last-child {
  border-bottom: none;
}

.spell-row.header {
  background: #eee5d8;
  color: #4f493f;
  font-size: 0.72rem;
  font-weight: 800;
  text-transform: uppercase;
}

.spell-row > span:nth-child(2) {
  display: grid;
  gap: 2px;
}

.empty-state {
  padding: 18px;
}

.empty-state p {
  margin: 0;
  color: #49443d;
}

.sheet-spell-lists {
  display: flex;
  gap: 10px;
  overflow-x: auto;
  overflow-y: hidden;
  padding-bottom: 10px;
  scroll-snap-type: x mandatory;
  scrollbar-color: #9fba99 #f0e8db;
  scrollbar-width: thin;
  touch-action: pan-x;
}

.sheet-spell-lists::-webkit-scrollbar {
  height: 10px;
}

.sheet-spell-lists::-webkit-scrollbar-track {
  border-radius: 999px;
  background: #f0e8db;
}

.sheet-spell-lists::-webkit-scrollbar-thumb {
  border: 2px solid #f0e8db;
  border-radius: 999px;
  background: #9fba99;
}

.sheet-spell-list {
  flex: 0 0 calc((100% - 20px) / 3);
  min-width: 230px;
  border: 1px solid #e2d9cc;
  border-radius: 6px;
  background: #faf4e8;
  padding: 10px;
  scroll-snap-align: start;
}

.sheet-spell-list h3 {
  margin: 0 0 2px;
  font-size: 0.92rem;
}

.sheet-spell-list ol {
  display: grid;
  gap: 4px;
  margin: 10px 0 0;
  padding: 0;
  list-style: none;
}

.sheet-spell-list li {
  display: grid;
  grid-template-columns: 28px minmax(0, 1fr) auto;
  gap: 8px;
  align-items: baseline;
  border-bottom: 1px solid #ede5d8;
  padding-bottom: 4px;
  font-size: 0.82rem;
}

.sheet-spell-list li:last-child {
  border-bottom: none;
}

.sheet-spell-list li span {
  color: #7a7060;
  font-weight: 800;
}

/* Prime stat hint bar */
.prime-stat-hint {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 10px;
  margin-bottom: 10px;
  padding: 8px 12px;
  border: 1px solid #b8d4cc;
  border-radius: 6px;
  background: #e0eee8;
  font-size: 0.88rem;
  color: #1e4a3b;
}

.prime-stat-hint-label {
  font-weight: 700;
  white-space: nowrap;
}

.prime-stat-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
}

.prime-stat-chip {
  display: inline-flex;
  align-items: baseline;
  gap: 6px;
  border: 1px solid var(--prime-border, #b8d4cc);
  border-radius: 999px;
  background: var(--prime-bg, #fffdf8);
  color: var(--prime-fg, #1f2522);
  padding: 5px 9px;
}

.prime-stat-chip b {
  font-size: 0.86rem;
}

.prime-stat-chip small {
  color: inherit;
  font-size: 0.72rem;
  font-weight: 700;
  opacity: 0.82;
}

.prime-stat-chip--ag { --prime-bg: #edf5ff; --prime-border: #8fadd0; --prime-fg: #214d7a; }
.prime-stat-chip--co { --prime-bg: #edf6e8; --prime-border: #9fba99; --prime-fg: #315b2e; }
.prime-stat-chip--me { --prime-bg: #f2ebfb; --prime-border: #b9a4d3; --prime-fg: #543878; }
.prime-stat-chip--re { --prime-bg: #eaf6f5; --prime-border: #8bbfb9; --prime-fg: #235c56; }
.prime-stat-chip--sd { --prime-bg: #fff7dc; --prime-border: #c8a84d; --prime-fg: #6c5214; }
.prime-stat-chip--em { --prime-bg: #fff0f3; --prime-border: #d49aaa; --prime-fg: #7a3044; }
.prime-stat-chip--in { --prime-bg: #edf2e5; --prime-border: #a9b978; --prime-fg: #455922; }
.prime-stat-chip--pr { --prime-bg: #f5efe5; --prime-border: #c9b081; --prime-fg: #60491e; }
.prime-stat-chip--qu { --prime-bg: #eef0ff; --prime-border: #9da6d8; --prime-fg: #39427f; }
.prime-stat-chip--st { --prime-bg: #f9ede8; --prime-border: #b98273; --prime-fg: #7e2f22; }

.xp-level-card {
  display: grid;
  align-content: center;
  gap: 8px;
  min-width: 0;
}

.xp-level-card > div:first-child {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 10px;
}

.xp-level-card span {
  color: #31584d;
  font-weight: 800;
}

.xp-level-card strong {
  color: #302b25;
}

.xp-level-card small {
  color: #6a6258;
  font-weight: 700;
}

.xp-level-card--sheet {
  min-width: min(100%, 320px);
  padding-bottom: 1px;
}

.xp-meter {
  display: block;
  height: 14px;
  overflow: hidden;
  border: 1px solid #b8d4cc;
  border-radius: 999px;
  background: #fffdf8;
}

.xp-meter span {
  display: block;
  width: 0;
  height: 100%;
  border-radius: inherit;
  background: linear-gradient(90deg, #427263, #c8a84d);
}

/* Prime stat row in the stats table */
.skill-row--prime {
  background: #eaf4ef;
}

.skill-row--prime b {
  color: #1e4a3b;
}

.stat-input {
  max-width: 90px;
  padding: 6px 10px;
  text-align: right;
}

.stat-final-boosted {
  color: #2d6e55;
  font-weight: 700;
}

.stat-final-penalized {
  color: #8b2a2a;
  font-weight: 700;
}

.xp-panel strong.over {
  color: #8b2a2a;
}

@media (max-width: 880px) {
  .shell {
    grid-template-columns: 1fr;
  }

  .shell.sidebar-collapsed {
    grid-template-columns: 1fr;
  }

  .sidebar {
    position: static;
    height: auto;
  }

  .tabs {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .step-progress {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .step-progress span {
    grid-template-columns: 1fr;
    justify-items: center;
    min-height: 44px;
    padding: 7px;
    text-align: center;
  }

  .step-progress .tab-label {
    font-size: 0.72rem;
  }

  .section-head,
  .toolbar,
  .filter-bar,
  .xp-panel {
    display: grid;
  }

  .creator-topbar {
    grid-template-columns: 36px minmax(0, 1fr);
  }

  .creator-identity,
  .snapshot--top {
    grid-column: 1 / -1;
  }

  .snapshot--top {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .flow-progress {
    grid-template-columns: repeat(10, minmax(64px, 1fr));
    overflow-x: auto;
    padding-bottom: 10px;
  }

  .flow-progress::before {
    left: 32px;
    right: 32px;
  }

  .flow-progress small {
    font-size: 0.68rem;
  }

  .search {
    max-width: none;
  }

  .section-actions {
    width: 100%;
    min-width: 0;
    flex-wrap: wrap;
  }

  .section-actions .search {
    flex-basis: 100%;
  }

  .split-band {
    grid-template-columns: 1fr;
  }

  .spell-layout {
    grid-template-columns: 1fr;
  }

  .spell-row {
    grid-template-columns: 42px minmax(0, 1fr);
  }

  .spell-row.header span:nth-child(n + 3),
  .spell-row span:nth-child(n + 3) {
    display: none;
  }

  .table-list label,
  .skill-row {
    grid-template-columns: 1fr;
  }

  .skill-table--skills .skill-row.header {
    top: 132px;
  }

  .modal-facts {
    grid-template-columns: 1fr;
  }

  .profession-modal-layout {
    grid-template-columns: 1fr;
  }

  .profession-modal-inspector {
    position: static;
    max-height: none;
  }

  .sheet-stats-row {
    grid-template-columns: repeat(5, 1fr);
  }

  .sheet-summary-line {
    grid-template-columns: 1fr;
    align-items: stretch;
  }

  .sheet-spell-list {
    flex-basis: min(82vw, 320px);
  }

  .sheet-lower-grid {
    grid-template-columns: 1fr;
  }

  .sheet-lower-grid .sheet-section {
    border-right: none;
    border-bottom: 1px solid #e2d9cc;
  }

  /* Wizard nav */
  .tabs {
    display: none;
  }

  .snapshot {
    display: flex;
    flex-wrap: wrap;
    gap: 10px 20px;
    margin: 12px 0 0;
  }

  .snapshot div {
    border-top: none;
    padding-top: 0;
  }

  .workspace {
    padding-bottom: 72px;
  }

  .shell.summary-only .workspace {
    padding: 14px;
  }

  .wizard-nav {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 20;
    margin: 0;
    border-right: none;
    border-bottom: none;
    border-left: none;
    border-radius: 0;
    padding: 10px 16px;
  }

  .wizard-nav-step {
    font-size: 0.8rem;
  }

  .wizard-nav-btn {
    min-height: 42px;
    padding: 10px 18px;
  }

  .mobile-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    background: #e9e0d2;
    border-top: 1px solid #d5d0c6;
    padding: 10px 16px;
    z-index: 20;
  }

  .mobile-nav-step {
    font-size: 0.8rem;
    font-weight: 700;
    color: #4f493f;
    text-align: center;
    flex: 1;
  }

  .mobile-nav-btn {
    border: 1px solid #bdb3a3;
    border-radius: 6px;
    background: #fbf7ef;
    color: #302b25;
    padding: 10px 18px;
    font-weight: 700;
    min-height: 42px;
    white-space: nowrap;
  }

  .mobile-nav-btn--next {
    border-color: #427263;
    background: #e0eee8;
    color: #1e4a3b;
  }

  .mobile-nav-btn:disabled {
    opacity: 0.35;
    cursor: not-allowed;
  }
}

/* Dark theme */
:root {
  color: #ece7dc;
  background: #101413;
  color-scheme: dark;
}

body {
  background:
    radial-gradient(circle at 12% 0%, rgb(61 88 78 / 0.24), transparent 32rem),
    linear-gradient(180deg, #141817 0%, #0f1211 100%);
  color: #ece7dc;
}

.portal-shell,
.shell,
.workspace {

:root {
  font-family:
    Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  color: #1f2522;
  background: #f4f1ea;
  font-synthesis: none;
  text-rendering: optimizeLegibility;
}

* {
  box-sizing: border-box;
}

body {
  margin: 0;
  min-width: 320px;
}

button,
input,
select,
textarea {
  font: inherit;
}

button {
  cursor: pointer;
}

.portal-shell {
  display: grid;
  align-content: start;
  gap: 22px;
  min-height: 100vh;
  padding: 32px;
}

.portal-head {
  display: flex;
  align-items: end;
  justify-content: space-between;
  gap: 16px;
  border-bottom: 1px solid #d5d0c6;
  padding-bottom: 18px;
}

.portal-head p {
  margin: 0 0 3px;
  color: #6a6258;
  font-size: 0.8rem;
  font-weight: 800;
  text-transform: uppercase;
}

.user-grid,
.character-library {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
  gap: 12px;
}

.user-card,
.character-card,
.empty-library {
  border: 1px solid #d5d0c6;
  border-radius: 8px;
  background: #fffaf1;
  color: #1f2522;
}

.user-card {
  display: grid;
  justify-items: start;
  gap: 8px;
  min-height: 190px;
  padding: 18px;
  text-align: left;
}

.user-card:hover,
.character-card:hover {
  border-color: #427263;
  box-shadow: 0 8px 24px rgb(31 37 34 / 0.08);
}

.user-avatar {
  display: grid;
  place-items: center;
  width: 48px;
  height: 48px;
  border: 1px solid #b8d4cc;
  border-radius: 8px;
  background: #e0eee8;
  color: #1e4a3b;
  font-size: 1.35rem;
  font-weight: 800;
}

.user-card strong,
.character-card strong {
  font-size: 1.1rem;
}

.user-card span:last-child {
  color: #6a6258;
  font-size: 0.86rem;
  font-weight: 700;
}

.character-card {
  display: grid;
  align-content: start;
  gap: 14px;
  padding: 16px;
}

.character-card > div:first-child {
  display: grid;
  gap: 3px;
}

.character-card dl {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 8px;
  margin: 0;
}

.character-card dl div {
  display: grid;
  gap: 3px;
  border: 1px solid #e2d9cc;
  border-radius: 6px;
  background: #f7f0e4;
  padding: 8px;
}

.character-card dt {
  color: #6a6258;
  font-size: 0.68rem;
  font-weight: 800;
  text-transform: uppercase;
}

.character-card dd {
  margin: 0;
  font-weight: 800;
}

.card-actions,
.identity-nav {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.primary-action,
.back-link,
.card-actions button,
.identity-nav button {
  border: 1px solid #bdb3a3;
  border-radius: 6px;
  background: #fbf7ef;
  color: #302b25;
  min-height: 38px;
  padding: 8px 12px;
  font-weight: 700;
}

.primary-action {
  border-color: #427263;
  background: #e0eee8;
  color: #1e4a3b;
}

.back-link {
  align-self: center;
}

.danger-action {
  border-color: #b98273 !important;
  background: #fff7f2 !important;
  color: #7e2f22 !important;
}

.empty-library {
  display: grid;
  justify-items: start;
  gap: 10px;
  padding: 24px;
}

.empty-library p {
  margin: 0;
  color: #49443d;
}

.shell {
  display: grid;
  grid-template-columns: minmax(0, 1fr);
  min-height: 100vh;
}

.shell.summary-only {
  grid-template-columns: minmax(0, 1fr);
}

.shell.summary-only .workspace {
  padding: 28px;
}

.sidebar {
  position: sticky;
  top: 0;
  height: 100vh;
  overflow: auto;
  border-right: 1px solid #d5d0c6;
  background: #e9e0d2;
  padding: 20px;
}

.sidebar.collapsed {
  padding: 12px 10px;
}

.sidebar-toggle {
  display: grid;
  place-items: center;
  width: 100%;
  min-height: 36px;
  border: 1px solid #bdb3a3;
  border-radius: 6px;
  background: #fbf7ef;
  color: #302b25;
  font-weight: 800;
}

.identity {
  display: grid;
  gap: 8px;
  margin-bottom: 20px;
}

.identity > small {
  color: #31584d;
  font-weight: 800;
}

.creator-topbar {
  display: grid;
  grid-template-columns: 36px minmax(210px, 300px) minmax(360px, 1fr);
  align-items: center;
  gap: 10px;
  border: 1px solid #d5d0c6;
  border-radius: 8px;
  background: #e9e0d2;
  margin-bottom: 10px;
  padding: 8px;
}

.identity-nav {
  display: flex;
  align-items: center;
  gap: 0;
}

.home-button {
  display: grid;
  place-items: center;
  width: 34px;
  min-height: 34px;
  padding: 0;
  border: 1px solid #bdb3a3;
  border-radius: 6px;
  background: #fbf7ef;
  color: #302b25;
  font-size: 1rem;
  font-weight: 900;
}

.creator-identity {
  display: grid;
  gap: 3px;
}

.creator-identity small {
  color: #31584d;
  font-size: 0.78rem;
  font-weight: 800;
}

.creator-identity label {
  color: #60584f;
  font-size: 0.66rem;
  font-weight: 800;
  text-transform: uppercase;
}

.snapshot--top {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 6px;
  margin: 0;
}

.snapshot--top div {
  border: 1px solid #d5d0c6;
  border-radius: 6px;
  background: #fffaf1;
  padding: 5px 7px;
}

.snapshot--top dt {
  font-size: 0.62rem;
}

.snapshot--top dd {
  margin-top: 1px;
  font-size: 0.82rem;
  line-height: 1.15;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.flow-progress {
  position: relative;
  display: grid;
  grid-template-columns: repeat(10, minmax(0, 1fr));
  gap: 0;
  margin: 0 0 16px;
  padding: 8px 0 0;
  min-width: 0;
}

.flow-progress::before {
  content: "";
  position: absolute;
  top: 23px;
  left: calc(100% / 18);
  right: calc(100% / 18);
  height: 2px;
  background: #d5d0c6;
}

.flow-progress button {
  position: relative;
  z-index: 1;
  display: grid;
  justify-items: center;
  gap: 6px;
  min-width: 0;
  border: 0;
  background: transparent;
  color: #6a6258;
  font: inherit;
  text-align: center;
  cursor: pointer;
}

.flow-progress button:hover b,
.flow-progress button:focus-visible b {
  transform: translateY(-1px);
  box-shadow: 0 0 0 4px rgb(66 114 99 / 0.14);
}

.flow-progress button:focus-visible {
  outline: 2px solid #427263;
  outline-offset: 4px;
  border-radius: 8px;
}

.flow-progress b {
  display: grid;
  place-items: center;
  width: 32px;
  height: 32px;
  border: 2px solid #bdb3a3;
  border-radius: 999px;
  background: #fbf7ef;
  color: #302b25;
  font-size: 0.86rem;
  transition: transform 0.14s ease, box-shadow 0.14s ease;
}

.flow-progress small {
  max-width: 100%;
  color: inherit;
  font-size: 0.64rem;
  font-weight: 800;
  line-height: 1.1;
  overflow-wrap: anywhere;
}

.flow-progress button.done b {
  border-color: #427263;
  background: #e0eee8;
  color: #1e4a3b;
}

.flow-progress button.active {
  color: #302b25;
}

.flow-progress button.active b {
  border-color: #c8a84d;
  background: #fff7dc;
  color: #6c5214;
  box-shadow: 0 0 0 4px rgb(200 168 77 / 0.18);
}

.sidebar.collapsed .identity,
.sidebar.collapsed .snapshot {
  display: none;
}

.identity label,
.xp-panel label {
  color: #60584f;
  font-size: 0.8rem;
  font-weight: 700;
  text-transform: uppercase;
}

input,
select,
textarea {
  width: 100%;
  border: 1px solid #c6bdae;
  border-radius: 6px;
  background: #fffdf8;
  color: #1f2522;
  padding: 10px 12px;
}

textarea {
  min-height: 110px;
  resize: vertical;
}

.tabs {
  display: grid;
  gap: 6px;
  margin-top: 12px;
}

.step-progress {
  display: grid;
  gap: 7px;
  margin-top: 12px;
}

.step-progress span {
  display: grid;
  grid-template-columns: 28px minmax(0, 1fr);
  align-items: center;
  gap: 8px;
  min-height: 38px;
  border: 1px solid #bdb3a3;
  border-radius: 6px;
  background: #fbf7ef;
  color: #302b25;
  padding: 7px 9px;
}

.step-progress b {
  display: grid;
  place-items: center;
  width: 24px;
  height: 24px;
  border-radius: 999px;
  background: #e9e0d2;
  font-size: 0.78rem;
}

.step-progress span.active {
  border-color: #427263;
  background: #e0eee8;
}

.step-progress span.done {
  color: #6a6258;
}

.tabs button,
.tier-control button,
.actions button,
.xp-panel button {
  border: 1px solid #bdb3a3;
  border-radius: 6px;
  background: #fbf7ef;
  color: #302b25;
  min-height: 38px;
  padding: 8px 10px;
}

.tabs button {
  text-align: left;
}

.tab-short {
  display: none;
}

.sidebar.collapsed .tabs button {
  display: grid;
  place-items: center;
  min-height: 42px;
  padding: 8px;
  text-align: center;
}

.sidebar.collapsed .tab-label {
  display: none;
}

.sidebar.collapsed .tab-short {
  display: inline;
  font-size: 1.15rem;
  font-weight: 800;
  line-height: 1;
}

.tabs button.active,
.tier-control button.active,
.choice.selected,
.package-grid article.selected {
  border-color: #427263;
  background: #e0eee8;
}

.snapshot {
  display: grid;
  gap: 12px;
  margin: 24px 0 0;
}

.snapshot div {
  border-top: 1px solid #d5d0c6;
  padding-top: 10px;
}

.snapshot dt {
  color: #6a6258;
  font-size: 0.78rem;
  font-weight: 700;
  text-transform: uppercase;
}

.snapshot dd {
  margin: 3px 0 0;
  font-weight: 700;
}

.workspace {
  min-width: 0;
  padding: 26px;
}

.section-head {
  display: flex;
  align-items: end;
  justify-content: space-between;
  gap: 18px;
  border-bottom: 1px solid #d5d0c6;
  padding-bottom: 18px;
  margin-bottom: 18px;
}

.section-head p {
  margin: 0 0 3px;
  color: #6a6258;
  font-size: 0.8rem;
  font-weight: 800;
  text-transform: uppercase;
}

h1,
h2 {
  letter-spacing: 0;
}

h1 {
  margin: 0;
  font-size: 1.75rem;
}

h2 {
  margin: 0 0 10px;
  font-size: 1rem;
}

.search {
  max-width: 340px;
}

.section-actions {
  display: flex;
  align-items: center;
  justify-content: end;
  gap: 8px;
  min-width: min(100%, 530px);
}

.section-actions .search {
  flex: 1 1 260px;
  max-width: none;
}

.section-actions--nav {
  min-width: auto;
}

.sort-toggle {
  flex: 0 0 auto;
  border: 1px solid #bdb3a3;
  border-radius: 6px;
  background: #fbf7ef;
  min-height: 40px;
  padding: 8px 10px;
  color: #5b5146;
  font-size: 0.78rem;
  font-weight: 900;
  min-width: 54px;
}

.inline-back,
.inline-next {
  flex: 0 0 auto;
  border: 1px solid #bdb3a3;
  border-radius: 6px;
  background: #fbf7ef;
  color: #302b25;
  min-height: 42px;
  padding: 9px 14px;
  font-weight: 800;
  white-space: nowrap;
}

.inline-next {
  border: 1px solid #427263;
  background: #e0eee8;
  color: #1e4a3b;
}

.inline-back:disabled {
  opacity: 0.35;
  cursor: not-allowed;
}

.list-grid,
.package-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
  gap: 10px;
}

.choice,
.package-grid article,
.detail-band,
.split-band {
  border: 1px solid #d5d0c6;
  border-radius: 6px;
  background: #fffaf1;
}

.choice {
  display: grid;
  gap: 8px;
  min-height: 132px;
  padding: 14px;
  text-align: left;
}

.choice strong {
  font-size: 1rem;
}

.choice span,
.package-grid p,
.detail-band p,
.split-band p {
  color: #49443d;
  line-height: 1.4;
}

small {
  color: #746b60;
}

.detail-band,
.split-band {
  margin-top: 18px;
  padding: 16px;
}

.rules-template-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
  gap: 10px;
  margin-bottom: 14px;
}

.rules-template-card {
  display: grid;
  gap: 10px;
  border: 1px solid #d5d0c6;
  border-radius: 6px;
  background: #fffaf1;
  padding: 14px;
}

.rules-template-card.selected {
  border-color: #427263;
  background: #e0eee8;
}

.rules-template-card div {
  display: grid;
  gap: 2px;
}

.rules-template-card p {
  margin: 0;
  color: #49443d;
  line-height: 1.4;
}

.rules-template-card button {
  justify-self: start;
  border: 1px solid #427263;
  border-radius: 6px;
  background: #e0eee8;
  color: #1e4a3b;
  min-height: 38px;
  padding: 8px 12px;
  font-weight: 700;
}

.rules-template-card.selected button {
  background: #427263;
  color: #fffaf1;
}

.rule-tabs {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
  margin-bottom: 10px;
}

.rule-tabs--sheet {
  margin-bottom: 12px;
}

.rule-tab {
  border: 1px solid #bdb3a3;
  border-radius: 6px;
  background: #fbf7ef;
  color: #302b25;
  min-height: 36px;
  padding: 7px 12px;
  font-weight: 700;
}

.rule-tab.active {
  border-color: #427263;
  background: #e0eee8;
  color: #1e4a3b;
}

.rules-detail-stack,
.sheet-rule-stack {
  display: grid;
  gap: 14px;
}

.rules-detail,
.sheet-rule {
  border: 1px solid #d5d0c6;
  border-radius: 6px;
  background: #fffaf1;
  padding: 16px;
}

.rules-detail header {
  display: flex;
  align-items: start;
  justify-content: space-between;
  gap: 14px;
  border-bottom: 1px solid #e2d9cc;
  margin-bottom: 12px;
  padding-bottom: 10px;
}

.rules-detail header p {
  margin: 0 0 3px;
  color: #6a6258;
  font-size: 0.78rem;
  font-weight: 800;
  text-transform: uppercase;
}

.rules-detail header button {
  border: 1px solid #b98273;
  border-radius: 6px;
  background: #fff7f2;
  color: #7e2f22;
  min-height: 36px;
  padding: 7px 10px;
  font-weight: 700;
}

.rules-detail > p,
.sheet-rule p {
  color: #49443d;
  line-height: 1.45;
}

.rule-effects {
  display: grid;
  gap: 6px;
  margin: 10px 0 0;
  padding-left: 18px;
  color: #49443d;
  line-height: 1.4;
}

.rules-table-wrap {
  overflow-x: auto;
}

.rules-table {
  min-width: 1080px;
  border: 1px solid #e2d9cc;
  background: #fffdf8;
}

.rules-table th {
  background: #eee5d8;
  color: #4f493f;
  font-size: 0.72rem;
  font-weight: 800;
  text-transform: uppercase;
}

.rules-table td {
  vertical-align: top;
  line-height: 1.35;
}

.rules-table--sheet {
  min-width: 980px;
  font-size: 0.82rem;
}

.rule-type {
  display: inline-block;
  border: 1px solid #d5d0c6;
  border-radius: 999px;
  background: #f7f0e4;
  padding: 2px 8px;
  font-size: 0.74rem;
  font-weight: 800;
  white-space: nowrap;
}

.rule-type--uncommon {
  border-color: #9fba99;
  background: #edf6e8;
  color: #315b2e;
}

.rule-type--rare {
  border-color: #8fadd0;
  background: #edf5ff;
  color: #214d7a;
}

.rule-type--magical {
  border-color: #b9a4d3;
  background: #f2ebfb;
  color: #543878;
}

.rule-type--legendary {
  border-color: #c8a84d;
  background: #fff7dc;
  color: #6c5214;
}

.sheet-rule h3 {
  margin: 0 0 2px;
  font-size: 0.98rem;
}

.detail-band--compact {
  margin-top: 0;
  margin-bottom: 14px;
}

.split-band {
  display: grid;
  grid-template-columns: minmax(0, 0.9fr) minmax(340px, 1.1fr);
  gap: 20px;
}

.adolescence-compare {
  display: grid;
  overflow-x: auto;
  border: 1px solid #d5d0c6;
  border-bottom: 0;
  background: #fffaf1;
}

.adolescence-row {
  display: grid;
  grid-template-columns: minmax(240px, 1.2fr) 88px 92px 74px minmax(320px, 1.8fr);
  align-items: center;
  gap: 10px;
  min-width: 760px;
  min-height: 58px;
  border: 0;
  border-bottom: 1px solid #d5d0c6;
  border-radius: 0;
  background: #fffaf1;
  color: #302b25;
  padding: 10px 12px;
  text-align: left;
}

.adolescence-row--header {
  position: sticky;
  top: 0;
  z-index: 4;
  min-height: 42px;
  background: #eee5d8;
  color: #4f493f;
  font-size: 0.78rem;
  font-weight: 900;
  text-transform: uppercase;
  box-shadow: 0 2px 0 #d5d0c6;
}

.adolescence-row:not(.adolescence-row--header) {
  cursor: pointer;
}

.adolescence-row:not(.adolescence-row--header):hover,
.adolescence-row.selected {
  background: #e0eee8;
}

.adolescence-row > span:first-child {
  display: grid;
  gap: 3px;
}

.adolescence-row b {
  font-size: 0.95rem;
}

.adolescence-row small {
  font-size: 0.8rem;
  line-height: 1.35;
}

table {
  width: 100%;
  border-collapse: collapse;
  font-size: 0.9rem;
}

th,
td {
  border-bottom: 1px solid #e2d9cc;
  padding: 8px;
  text-align: left;
}

.compact-table {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 72px;
  gap: 0;
  border: 1px solid #e2d9cc;
  border-bottom: 0;
  font-size: 0.88rem;
}

.compact-table span,
.compact-table b {
  border-bottom: 1px solid #e2d9cc;
  padding: 7px 9px;
}

.compact-table b {
  text-align: right;
}

.toolbar,
.filter-bar,
.xp-panel {
  display: flex;
  align-items: end;
  gap: 12px;
  margin-bottom: 14px;
  border: 1px solid #d5d0c6;
  border-radius: 6px;
  background: #fffaf1;
  padding: 12px;
}

.toolbar strong {
  font-size: 1.25rem;
}

.toolbar strong.over {
  color: #8b2a2a;
}

.toolbar-budget {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  margin-left: auto;
  color: #60584f;
  font-size: 0.8rem;
  font-weight: 700;
  text-transform: uppercase;
}

.toolbar-budget input {
  width: 78px;
  border: 1px solid #c6bdae;
  border-radius: 6px;
  background: #fffdf8;
  color: #1f2522;
  font-size: 0.95rem;
  font-weight: 800;
  padding: 6px 8px;
}

.filter-bar label {
  display: grid;
  gap: 5px;
  min-width: min(100%, 340px);
  color: #60584f;
  font-size: 0.8rem;
  font-weight: 700;
  text-transform: uppercase;
}

.filter-bar strong {
  font-size: 1.2rem;
}

.table-list {
  display: grid;
  border: 1px solid #d5d0c6;
  border-bottom: 0;
  background: #fffaf1;
}

.table-list label,
.skill-row {
  display: grid;
  grid-template-columns: 28px minmax(220px, 1fr) minmax(150px, 0.45fr) 92px;
  align-items: center;
  gap: 10px;
  border-bottom: 1px solid #d5d0c6;
  min-height: 46px;
  padding: 8px 12px;
}

.talent-main,
.talent-meta,
.talent-cost {
  display: grid;
  gap: 3px;
}

.talent-main strong {
  font-size: 0.95rem;
}

.talent-main small {
  line-height: 1.35;
}

.talent-cost {
  justify-items: end;
  text-align: right;
}

.talent-meta small:first-child {
  color: #31584d;
  font-weight: 800;
}

.table-list b,
